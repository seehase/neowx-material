                            #set $cc_id = $x + "chart"
                            $getChartJsCode($x, $cc_id, $cc_type, $s1, $s2, $cc_column, $s3, $s4, $s5, $s6, $s7, $s8)
                        #end if
                    #end if
                #end if
            #end for

        </script>

