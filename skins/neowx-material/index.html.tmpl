                                                #set $axis_cfg = $yaxis_config.get($axis_id, {})
                                                #set $axis_title = $axis_cfg.get('title', '')
                                                #set $axis_opposite_raw = $axis_cfg.get('opposite', None)
                                                ## Default: first axis on left (false), others on right (true)
                                                #if $axis_opposite_raw is None
                                                    #set $axis_opposite = 'true' if $idx > 0 else 'false'
                                                #else
                                                    #set $axis_opposite = 'true' if str($axis_opposite_raw).lower() in ['true', 'yes', '1'] else 'false'
                                                #end if
                                                #set $axis_decimals = $axis_cfg.get('decimals', None)
                                                #set $axis_min = $axis_cfg.get('min', None)
                                                #set $axis_max = $axis_cfg.get('max', None)
                                            {
                                                #set $asn_list = $axis_series_names.get($axis_id, [])
                                                #if not $asn_list
                                                    #set $asn_list = [$getVar('obs.label.' + $first_field)]
                                                #end if
                                                seriesName: [
                                                    #for $asn in $asn_list
                                                        "$asn",
                                                    #end for
                                                ],
                                                #if $axis_title
                                                title: {
                                                    text: "$axis_title",
                                                    style: {
                                                        fontSize: '12px',
                                                    }
                                                },
                                                #end if
                                                opposite: $axis_opposite,
                                                #if $axis_min is not None
                                                min: $axis_min,
                                                #end if
                                                #if $axis_max is not None
                                                max: $axis_max,
                                                #end if
                                                labels: {
                                                    formatter: function (val) {
                                                        #if $axis_decimals is not None
                                                        return formatNumber(val, "%.$axis_decimals\f") + "$getVar('unit.label.' + $first_field)";
                                                        #else
                                                        return formatNumber(val, "$getVar('unit.format.' + $first_field)") + "$getVar('unit.label.' + $first_field)";
                                                        #end if
                                                    }
                                                },
                                            },
                                            #end for
                                        ],
                                    #end if
                                    #if len($axes_list) > 1
                                    ## Multi-axis assigns each series an axis group, which makes ApexCharts
                                    ## cluster the legend by axis (out of series order). Keep series order.
                                    legend: { ...graph_${cc_type}_config.legend, clusterGroupedSeries: false },
                                    #end if
                                    series: [
                                        #set $cc_color_list = []
                                        #set $cc_pos = 0
                                        #for $val, $cols in $cc_series_pairs
                                            #if $chartHasData(val)
                                                {
                                                    name: "$getVar('obs.label.' + val)",
                                                    data: [ $getChartData(val, cols[0]) ]
                                                },
                                                #silent $cc_color_list.append($cc_color_refs[$cc_pos] if $cc_pos < len($cc_color_refs) else 'default')
                                            #end if
                                            #set $cc_pos = $cc_pos + 1
                                        #end for
                                    ],
                                    #if len($cc_color_refs) > 0 and len($cc_color_list) > 0
                                        #set $cc_color_count = len($cc_color_list)
                                        colors: neowxChartColors([
                                        #for $cref in $cc_color_list
                                            "$cref",
                                        #end for
                                        ], $cc_color_count, "$x"),
                                    #end if
                                }).render()
                            }
                        #end if
                    #end if
                #end if
            #end for

        </script>

