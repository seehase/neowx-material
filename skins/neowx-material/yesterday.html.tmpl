    <head>
        <title>
            $gettext("yesterday") | $station.location
        </title>
        #include "head.inc"
    </head>
    <body class="${Extras.Appearance.mode}-theme main-bg" ontouchstart="">

        #include "header.inc"

        <main>
            <div class="container-fluid d-flex-xxl">

                <div class="row mt-3 temprow align-content-start">
                    #set $val_panel_idx = 0
                    #for $seg in $val_segments
                        #if $seg['type'] is not None
                            #set $val_panel_idx = $val_panel_idx + 1
                        #end if
                        $renderValSegment($seg, $val_panel_idx)
                    #end for
                </div>

                <hr class="m-0 mb-4 rowdivider">

