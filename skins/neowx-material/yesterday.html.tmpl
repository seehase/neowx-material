                'E': {'sum': 0.0, 'amt': 0, 'avg': 0.0, 'max': 0.0},
                'SE': {'sum': 0.0, 'amt': 0, 'avg': 0.0, 'max': 0.0},
                'S': {'sum': 0.0, 'amt': 0, 'avg': 0.0, 'max': 0.0},
                'SW': {'sum': 0.0, 'amt': 0, 'avg': 0.0, 'max': 0.0},
                'W': {'sum': 0.0, 'amt': 0, 'avg': 0.0, 'max': 0.0},
                'NW': {'sum': 0.0, 'amt': 0, 'avg': 0.0, 'max': 0.0},
