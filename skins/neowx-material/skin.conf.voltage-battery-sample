#
# [[[[YOUR_SENSOR_NAME]]]]
#     enabled = yes
#     max_voltage = 4.5      # Change to your max voltage
#     min_voltage = 0.0      # Usually 0
#     low_threshold = 50     # Change to your preference (0-100)
#
# ====================================================================

